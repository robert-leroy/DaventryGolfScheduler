{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/GolfScheduler.Api/bin/Debug/net10.0/GolfScheduler.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/GolfScheduler.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "UI (Vue/Vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/src/golf-scheduler-ui",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "API + UI",
      "configurations": ["API (.NET)", "UI (Vue/Vite)"],
      "stopAll": true
    }
  ]
}
